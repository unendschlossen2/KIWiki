---
import BaseHead from "../components/layout/BaseHead.astro";
import Navbar from "../components/navigation/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import SearchModal from "../components/search/SearchModal.tsx";
import Sidebar from "../components/navigation/Sidebar.astro";
import TableOfContents from "../components/navigation/TableOfContents.tsx";
import "../styles/global.css";
import "../styles/layout.css";

interface Props {
	title?: string;
	description?: string;
	frontmatter?: any;
	category?: string;
}

const {
	title: propTitle,
	description: propDescription,
	frontmatter,
	category: propCategory,
} = Astro.props;

const title = frontmatter?.title || propTitle || "KIWiki";
const description =
	frontmatter?.description ||
	propDescription ||
	"Das interaktive Nachschlagewerk für Künstliche Intelligenz";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const isRoot = pathname === (base || "/");
const isArticle = pathname.includes(`${base}/articles/`);
const isUeber = pathname.includes(`${base}/info/ueber-das-projekt`);
const isCategory = pathname.includes(`${base}/category/`);
const isTag = pathname.includes(`${base}/tag/`);

const showSidebar = !isRoot && !isUeber && !isCategory && !isTag;
const isFullWidth = isRoot || isCategory || isTag;
---

<!doctype html>
<html lang="de" data-difficulty="easy" data-base={base}>
	<BaseHead title={title} description={description} />
	<body
		class="min-h-screen pt-20 bg-slate-50 dark:bg-slate-800 selection:bg-blue-100 selection:text-blue-900 dark:selection:bg-blue-900 dark:selection:text-blue-100 transition-colors duration-300"
	>
		<Navbar isArticle={isArticle} category={propCategory || frontmatter?.category} />

		<SearchModal client:only="react" />
		{showSidebar && <Sidebar />}

		<div
			class:list={[
				"layout-wrapper",
				{
					"has-sidebar": showSidebar,
					"full-width": isFullWidth,
				},
			]}
		>
			<main class="main-content">
				{
					frontmatter?.title && (
						<header class="mb-12">
							<h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4">
								{frontmatter.title}
							</h1>
							<div class="h-1.5 w-20 bg-blue-600 rounded-full" />
						</header>
					)
				}

				<article
					class="prose prose-slate dark:prose-invert lg:prose-xl prose-headings:text-slate-900 dark:prose-headings:text-white prose-headings:font-bold prose-a:text-blue-600 prose-img:rounded-2xl prose-pre:bg-slate-900 max-w-none transition-colors duration-300"
				>
					<slot />
				</article>

				<Footer />
			</main>

			{
				isArticle && (
					<aside class="toc-aside">
						<TableOfContents client:load />
					</aside>
				)
			}
		</div>

		<script>
			import { difficultyStore } from "../stores/difficultyStore";

			let unsubscribe: () => void;

			function initDifficultySync() {
				if (unsubscribe) unsubscribe();
				unsubscribe = difficultyStore.subscribe((newDifficulty) => {
					document.documentElement.setAttribute(
						"data-difficulty",
						newDifficulty,
					);
				});
			}

			document.addEventListener("astro:page-load", initDifficultySync);
		</script>

		<script>
			document.addEventListener("astro:page-load", () => {
				const progressBar = document.getElementById("reading-progress");

				const updateScroll = () => {
					const windowHeight = window.innerHeight;
					const documentHeight =
						document.documentElement.scrollHeight - windowHeight;
					const scrollTop = window.scrollY;

					if (progressBar && documentHeight > 0) {
						const progress = Math.min(
							(scrollTop / documentHeight) * 100,
							100,
						);
						progressBar.style.width = `${progress}%`;
					}
				};

				if (progressBar) {
					window.addEventListener("scroll", updateScroll, { passive: true });
					window.requestAnimationFrame(updateScroll);
				}
			});
		</script>
	</body>
</html>

<style is:global>
	/* Custom scrollbar for premium feel */
	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		background: transparent;
	}
	::-webkit-scrollbar-thumb {
		background: var(--border-color);
		border-radius: 20px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: var(--border-hover);
	}

	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>
