---
/**
 * ArticleGlyph.astro
 * Generates a unique, deterministic SVG "Neural Fingerprint" based on article title and category.
 */
interface Props {
  title: string;
  category?: string;
  size?: number;
}

const { title, category = "default", size = 48 } = Astro.props;

// Simple deterministic hash from string
function getSeed(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = (hash << 5) - hash + str.charCodeAt(i);
    hash |= 0; // Convert to 32bit integer
  }
  return Math.abs(hash);
}

const seed = getSeed(title);

// LCG random generator for deterministic results
function random(s: number) {
  const x = Math.sin(s) * 10000;
  return x - Math.floor(x);
}

// Generate points
const pointCount = 4 + (seed % 4); // 4 to 7 points
const points = Array.from({ length: pointCount }).map((_, i) => ({
  x: 20 + random(seed + i) * 60,
  y: 20 + random(seed + i * 2) * 60,
}));

// Determine category-specific frame shape
// We use a clip-path or a background shape
const categoryShapes: Record<string, string> = {
  // Fundament & Lernmethoden
  "Grundlagen & Mathematische Theorie": "polygon(20% 0%, 80% 0%, 100% 20%, 100% 80%, 80% 100%, 20% 100%, 0% 80%, 0% 20%)", // Octagon
  "Klassisches Maschinelles Lernen": "inset(10% round 20%)", // Rounded Square
  "Deep Learning & Neuronale Netze": "polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%)", // Hexagon
  "Reinforcement Learning & Agenten-Systeme": "polygon(50% 0%, 100% 100%, 0% 100%)", // Triangle

  // Modalitäten & Modelle
  "Natural Language Processing (NLP)": "polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)", // Diamond
  "Computer Vision & Bildverarbeitung": "polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%)", // Shield
  "Generative KI & Foundation Models": "circle(50%)", // Circle
  "Audio-, Sprach- & Musikverarbeitung": "polygon(0% 0%, 100% 0%, 100% 70%, 50% 100%, 0% 70%)", // Waveform/Shield

  // Praxis & Engineering
  "Robotik & Embodied AI": "inset(0% 20% 0% 20%)", // Vertical Bar/Robot
  "Daten, Datensätze & Infrastruktur": "polygon(0% 15%, 100% 15%, 100% 85%, 0% 85%)", // Data Stack
  "MLOps, Engineering & Hardware": "polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)", // Nut/Gear

  // Gesellschaft
  "Ethik, Sicherheit & KI-Alignment": "polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%)", // Pentagram/Balance
  "Branchen & Praktische Anwendungen": "polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%)", // Star
  "Geschichte, Akteure & Organisationen": "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%, 20% 50%)", // Ribbon
  "default": "circle(50%)"
};

const shape = categoryShapes[category] || categoryShapes.default;
---

<div class="glyph-container" style={`width: ${size}px; height: ${size}px;`}>
  <div class="glyph-bg" style={`clip-path: ${shape};`}></div>
  <svg 
    viewBox="0 0 100 100" 
    class="glyph-svg"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Connections -->
    {points.map((p, i) => (
      points.slice(i + 1, i + 3).map((p2) => (
        <line 
          x1={p.x} y1={p.y} 
          x2={p2.x} y2={p2.y} 
          stroke="currentColor" 
          stroke-width="1.5" 
          stroke-opacity="0.4"
          class="glyph-line"
        />
      ))
    ))}
    
    <!-- Nodes -->
    {points.map((p) => (
      <circle 
        cx={p.x} cy={p.y} 
        r="3" 
        fill="currentColor"
        class="glyph-node"
      />
    ))}
  </svg>
</div>

<style>
  .glyph-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-color);
    transition: all 0.4s ease;
  }

  .glyph-bg {
    position: absolute;
    inset: 0;
    background: var(--primary-color);
    opacity: 0.1;
    transition: all 0.4s ease;
  }

  .glyph-svg {
    position: relative;
    z-index: 1;
    width: 80%;
    height: 80%;
    filter: drop-shadow(0 0 4px var(--primary-color-alpha));
  }

  .glyph-line {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: glyph-draw 1.5s ease-out forwards;
  }

  .glyph-node {
    transform: scale(0);
    animation: glyph-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes glyph-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes glyph-pop {
    to { transform: scale(1); }
  }

  /* React to hover of parent .library-tile */
  :global(.library-tile:hover) .glyph-bg {
    opacity: 0.2;
    transform: scale(1.1);
  }

  :global(.library-tile:hover) .glyph-container {
    transform: rotate(15deg);
  }
</style>
