---
import { getCollection } from "astro:content";
import { slugifyCategory } from "../utils/slugify";
import { categoryIcons } from "../config/categories";

const articles = (await getCollection("articles")).filter(
	(a) => !a.id.startsWith("_"),
);

const categories = [...new Set(articles.map((a) => a.data.category))].sort();
---

<div class="horizontal-scroll-container">
	<div class="flex items-center gap-2 pr-8">
		<a
			href="/KIWiki/"
			class="flex items-center justify-center min-w-[36px] h-[36px] rounded-full bg-slate-100 dark:bg-slate-800 hover:bg-white dark:hover:bg-slate-700 border border-transparent hover:border-slate-200 dark:hover:border-slate-600 text-slate-600 dark:text-slate-300 transition-all shadow-sm hover:shadow flex-shrink-0"
			aria-label="Zur Startseite"
			title="🏠 Startseite"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="transition-transform duration-200" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
		</a>

		<div class="w-px h-5 bg-slate-200 dark:bg-slate-700 flex-shrink-0 mx-1"></div>

		{
			categories.map((cat) => (
				<a
					href={`/KIWiki/category/${slugifyCategory(cat)}`}
					class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-100 dark:bg-slate-800 hover:bg-white dark:hover:bg-slate-700 border border-transparent hover:border-slate-200 dark:hover:border-slate-600 text-slate-600 dark:text-slate-300 text-sm font-medium rounded-full whitespace-nowrap transition-all shadow-sm hover:shadow flex-shrink-0"
				>
					<span class="opacity-80">{categoryIcons[cat] || "📂"}</span>
					<span>{cat}</span>
				</a>
			))
		}
	</div>
</div>

<style>
	.horizontal-scroll-container {
		width: 100%;
		overflow-x: auto;
		scrollbar-width: none; /* Firefox */
		-ms-overflow-style: none; /* IE/Edge */
		-webkit-mask-image: linear-gradient(to right, black 90%, transparent 100%);
		mask-image: linear-gradient(to right, black 90%, transparent 100%);
	}
	.horizontal-scroll-container::-webkit-scrollbar {
		display: none; /* Chrome/Safari */
	}
</style>
