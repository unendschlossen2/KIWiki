---
import { getCollection } from "astro:content";
import { slugifyCategory } from "../../utils/slugify";
import { DIFFICULTY_LABELS, DIFFICULTY_SHORT } from "../../config/difficulty";

const allArticles = (await getCollection("articles")).filter(
  (a) => !a.id.startsWith("_"),
);
const currentPath = Astro.url.pathname;

// 1. Find active category
let activeCategory: string | null = null;

// Clean path for matching (remove base and trailing slashes)
const path = currentPath.replace(/^\/KIWiki/, "").replace(/\/$/, "") || "/";

// Case 1: On a category page (/category/[slug])
if (path.startsWith("/category/")) {
  const slug = path.split("/").pop();
  const found = allArticles.find(
    (a) => slugifyCategory(a.data.category) === slug,
  );
  if (found) activeCategory = found.data.category;
}

// Case 2: On an article page (/articles/[...slug])
else if (path.startsWith("/articles/")) {
  const slug = path.replace("/articles/", "");
  const article = allArticles.find((a) => a.id.replace(/\.mdx?$/, "") === slug);
  if (article) activeCategory = article.data.category;
}

// 2. Filter grouped articles to only show ONE active category
const groupedArticles = allArticles.reduce(
  (acc, article) => {
    const category = article.data.category;

    // Only show if it matches the active category
    if (activeCategory && category === activeCategory) {
      if (!acc[category]) acc[category] = [];
      acc[category].push(article);
    }
    return acc;
  },
  {} as Record<string, typeof allArticles>,
);
---

<aside id="sidebar" class="sidebar" data-collapsed="true">
  <button
    id="sidebar-toggle"
    class="sidebar-toggle"
    aria-label="Navigation öffnen/schließen"
  >
    <svg
      id="hamburger-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
    <svg
      id="close-icon"
      class="hidden"
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <nav class="sidebar-nav" id="sidebar-nav">
    <a
      href="/KIWiki/"
      class="sidebar-header-main transition-transform hover:scale-[1.02] active:scale-[0.98]"
    >
      <div class="sidebar-logo-wrapper">
        <img
          src="/KIWiki/assets/logo.png"
          alt="KIWiki Logo"
          class="sidebar-logo"
        />
      </div>
      <div class="sidebar-brand-text">
        <span class="brand-name">KIWiki</span>
        <span class="brand-tag">powered by JadeHS</span>
      </div>
    </a>

    {
      Object.entries(groupedArticles).map(([category, items]) => (
        <div class="sidebar-category">
          <a
            href={`/KIWiki/category/${slugifyCategory(category)}`}
            class="sidebar-header block transition-colors hover:bg-slate-50 dark:hover:bg-slate-800/50 rounded-lg mx-2 px-3 py-2.5"
            style="margin-top: 1rem; margin-bottom: 0.25rem; text-decoration: none;"
          >
            <span class="sidebar-title hover:text-blue-600 dark:hover:text-blue-400 transition-colors uppercase cursor-pointer block">
              {category}
            </span>
          </a>
          <ul class="sidebar-list">
            {items.map((article) => {
              const slug = article.id.replace(/\.mdx?$/, "");
              const href = `/KIWiki/articles/${slug}`;
              const isActive = currentPath.includes(slug);
              const difficulties = article.data.difficulties;
              const isRestricted = difficulties && difficulties.length < 3;

              return (
                <li
                  class="sidebar-item"
                  data-difficulties={difficulties?.join(",")}
                >
                  <a
                    href={href}
                    class:list={["sidebar-link", { active: isActive }]}
                  >
                    <span>{article.data.title}</span>
                    {isRestricted && (
                      <span class="difficulty-badges">
                        {difficulties.includes("easy") && (
                          <span
                            class="badge badge-easy"
                            title={DIFFICULTY_LABELS.easy}
                          >
                            {DIFFICULTY_SHORT.easy}
                          </span>
                        )}
                        {difficulties.includes("medium") && (
                          <span
                            class="badge badge-medium"
                            title={DIFFICULTY_LABELS.medium}
                          >
                            {DIFFICULTY_SHORT.medium}
                          </span>
                        )}
                        {difficulties.includes("hard") && (
                          <span
                            class="badge badge-hard"
                            title={DIFFICULTY_LABELS.hard}
                          >
                            {DIFFICULTY_SHORT.hard}
                          </span>
                        )}
                      </span>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 80px; /* below navbar */
    left: 0;
    bottom: 0;
    width: 260px;
    z-index: 40;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-color);
    transform: translateX(0);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }

  .sidebar[data-collapsed="true"] {
    transform: translateX(-100%);
  }

  @media (min-width: 1024px) {
    .sidebar {
      transform: translateX(0) !important;
    }
  }

  .sidebar-toggle {
    position: fixed;
    top: 88px;
    left: 12px;
    z-index: 50;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 8px;
    cursor: pointer;
    color: var(--text-secondary);
    box-shadow: 0 1px 3px var(--shadow-color);
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar-toggle:hover {
    background: var(--bg-page);
    color: var(--primary-color);
  }

  @media (min-width: 1024px) {
    .sidebar-toggle {
      display: none;
    }
  }

  .sidebar-nav {
    padding: 16px 0;
  }

  .sidebar-header-main {
    padding: 32px 20px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 16px;
    text-align: center;
  }

  .sidebar-logo-wrapper {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    overflow: hidden;
    background: white;
    padding: 6px;
    border: 2px solid var(--border-color);
    box-shadow: 0 4px 12px var(--shadow-color);
  }

  .sidebar-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sidebar-brand-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .brand-name {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.025em;
  }

  .brand-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .sidebar-title {
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 20px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.15s;
    border-left: 3px solid transparent;
  }

  .sidebar-link:hover {
    background: var(--bg-page);
    color: var(--text-primary);
    border-left-color: var(--border-hover);
  }

  .sidebar-link.active {
    background: var(--bg-active);
    color: var(--primary-color);
    border-left-color: var(--primary-color);
    font-weight: 600;
  }

  .hidden {
    display: none;
  }

  .difficulty-hidden {
    display: none !important;
  }
</style>

<script>
  import { difficultyStore } from "./difficultyStore";

  function updateSidebarVisibility(difficulty: string) {
    const items = document.querySelectorAll(".sidebar-item");
    items.forEach((item) => {
      const allowed =
        (item as HTMLElement).dataset.difficulties?.split(",") || [];
      if (allowed.includes(difficulty)) {
        item.classList.remove("difficulty-hidden");
      } else {
        item.classList.add("difficulty-hidden");
      }
    });

    // Hide categories that have no visible items
    const categories = document.querySelectorAll(".sidebar-category");
    categories.forEach((category) => {
      const visibleItems = category.querySelectorAll(
        ".sidebar-item:not(.difficulty-hidden)",
      );
      if (visibleItems.length === 0) {
        category.classList.add("difficulty-hidden");
      } else {
        category.classList.remove("difficulty-hidden");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    const sidebar = document.getElementById("sidebar");
    const toggle = document.getElementById("sidebar-toggle");
    const hamburger = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    if (toggle && sidebar && hamburger && closeIcon) {
      toggle.addEventListener("click", () => {
        const isCollapsed = sidebar.getAttribute("data-collapsed") === "true";
        sidebar.setAttribute("data-collapsed", isCollapsed ? "false" : "true");
        hamburger.classList.toggle("hidden");
        closeIcon.classList.toggle("hidden");
      });
    }

    // Subscribe to difficulty changes
    difficultyStore.subscribe((newDifficulty) => {
      updateSidebarVisibility(newDifficulty);
    });
  });
</script>
