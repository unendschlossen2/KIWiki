---
import { getCollection } from "astro:content";
import { slugifyCategory } from "../../utils/slugify";
import {
	sortCategories,
	getCategoryDisplay,
	getCategoryIcon,
	HEADER_CATEGORIES,
} from "../../config/categories";
import { resolvePath } from "../../utils/path";
import { DIFFICULTY_LABELS, DIFFICULTY_SHORT } from "../../config/difficulty";

const articles = (await getCollection("articles")).filter(
	(a) => !a.id.startsWith("_"),
);

const groupedByCat = articles.reduce(
	(acc, a) => {
		const cat = getCategoryDisplay(a.data.category);
		if (!acc[cat]) acc[cat] = [];
		acc[cat].push(a);
		return acc;
	},
	{} as Record<string, typeof articles>,
);

interface Props {
	currentCategory?: string;
}

const { currentCategory } = Astro.props;
const { category: urlCategorySlug } = Astro.params;

// Helper to check if a category is active
const checkActive = (catDisplay: string) => {
	const slug = slugifyCategory(catDisplay);
	if (urlCategorySlug === slug) return true;
	if (currentCategory) {
		const normalizedCurrent = currentCategory.toLowerCase();
		return (
			normalizedCurrent === slug ||
			normalizedCurrent === catDisplay.toLowerCase()
		);
	}
	return false;
};

const anyActive = !!urlCategorySlug || !!currentCategory;
---

<div class="relative flex items-center h-full">
	<button
		id="category-dropdown-btn"
		class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 font-bold transition-all border border-transparent dark:border-slate-700/50 shadow-sm whitespace-nowrap"
		aria-expanded="false"
	>
		<span>Themen</span>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="16"
			height="16"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			class="transition-transform duration-200"
			><path d="m6 9 6 6 6-6"></path></svg
		>
	</button>

	<div
		id="category-dropdown-panel"
		class="fixed left-1/2 -translate-x-1/2 top-20 w-[95vw] max-w-7xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-b-3xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] p-6 md:p-10 opacity-0 -translate-y-2 pointer-events-none transition-all duration-300 z-50 overflow-y-auto max-h-[85vh]"
	>
		<div
			class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8"
		>
			{
				Object.entries(HEADER_CATEGORIES).map(
					([headerName, categoryKeys]) => (
						<div class="header-section">
							<h3 class="text-[0.65rem] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-4 px-3">
								{headerName}
							</h3>

							<div class="space-y-1">
								{sortCategories(
									categoryKeys.map(getCategoryDisplay),
								).map((cat) => {
									const catArticles = groupedByCat[cat] || [];
									const slug = slugifyCategory(cat);
									const isActive = checkActive(cat);

									return (
										<div class="category-group">
											<div
												class:list={[
													"flex items-center justify-between px-3 py-1.5 rounded-xl transition-all group/item",
													isActive
														? "bg-blue-100 dark:bg-blue-900/50 ring-1 ring-blue-500/30 shadow-sm"
														: "hover:bg-blue-50 dark:hover:bg-blue-900/30 shadow-none border-transparent",
												]}
											>
												<a
													href={resolvePath(`/category/${slug}/`)}
													class="flex items-center gap-3 flex-1 py-1 overflow-hidden"
												>
													<span
														class:list={[
															"text-xl shrink-0 transition-all duration-300",
															!anyActive
																? "grayscale-0"
																: isActive
																	? "grayscale-0 scale-110"
																	: "grayscale opacity-40 group-hover/item:grayscale-0 group-hover/item:opacity-100",
														]}
													>
														{getCategoryIcon(cat)}
													</span>
													<span
														class:list={[
															"text-sm font-bold leading-tight truncate px-1",
															isActive
																? "text-blue-600 dark:text-blue-300"
																: "text-slate-700 dark:text-slate-200 group-hover/item:text-blue-600 dark:group-hover/item:text-blue-400",
														]}
													>
														{cat}
													</span>
												</a>

												<div class="flex items-center gap-1.5 shrink-0">
													<span
														class:list={[
															"text-[0.65rem] font-mono px-1.5 py-0.5 rounded-md transition-colors",
															isActive
																? "bg-blue-500 text-white"
																: "bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 group-hover/item:bg-white dark:group-hover/item:bg-slate-900",
														]}
													>
														{catArticles.length}
													</span>
													<button
														class="category-article-toggle p-1 rounded-lg text-slate-400 hover:text-blue-500 hover:bg-white dark:hover:bg-slate-800 transition-all"
														aria-label="Artikel anzeigen"
													>
														<svg
															xmlns="http://www.w3.org/2000/svg"
															width="14"
															height="14"
															viewBox="0 0 24 24"
															fill="none"
															stroke="currentColor"
															stroke-width="3"
															stroke-linecap="round"
															stroke-linejoin="round"
															class="chevron duration-300"
														>
															<path d="m6 9 6 6 6-6" />
														</svg>
													</button>
												</div>
											</div>

											<ul class="article-list hidden mt-1 space-y-0.5 pl-10 pr-2 pb-2">
												{catArticles.map((art) => (
													<li>
														<a
															href={resolvePath(`/articles/${art.id.replace(/\.mdx?$/, "")}/`)}
															class="flex items-center justify-between text-[0.8rem] font-semibold text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 py-1 transition-colors border-l-2 border-transparent hover:border-blue-500/40 pl-3 -ml-3"
														>
															<span class="truncate">
																{art.data.title}
															</span>
															{art.data
																.difficulties &&
																art.data
																	.difficulties
																	.length <
																	3 && (
																	<div class="flex gap-1 scale-[0.65] origin-right">
																		{art.data.difficulties.includes("easy") && (
																			<span class="badge badge-easy" title={DIFFICULTY_LABELS.easy}>
																				{DIFFICULTY_SHORT.easy}
																			</span>
																		)}
																		{art.data.difficulties.includes("medium") && (
																			<span class="badge badge-medium" title={DIFFICULTY_LABELS.medium}>
																				{DIFFICULTY_SHORT.medium}
																			</span>
																		)}
																		{art.data.difficulties.includes("hard") && (
																			<span class="badge badge-hard" title={DIFFICULTY_LABELS.hard}>
																				{DIFFICULTY_SHORT.hard}
																			</span>
																		)}
																	</div>
																)}
														</a>
													</li>
												))}
											</ul>
										</div>
									);
								})}
							</div>
						</div>
					),
				)
			}
		</div>
	</div>
</div>

<script>
	function setupDropdown() {
		const btn = document.getElementById("category-dropdown-btn");
		const panel = document.getElementById("category-dropdown-panel");

		if (!btn || !panel) return;

		// Toggle Dropdown Main
		btn.addEventListener("click", (e) => {
			e.stopPropagation();
			const isExpanded = btn.getAttribute("aria-expanded") === "true";

			// Close tag dropdown if open
			const tagBtn = document.getElementById("tag-dropdown-btn");
			if (tagBtn && tagBtn.getAttribute("aria-expanded") === "true") {
				tagBtn.click();
			}

			btn.setAttribute("aria-expanded", String(!isExpanded));

			if (!isExpanded) {
				panel.classList.remove(
					"opacity-0",
					"-translate-y-2",
					"pointer-events-none",
				);
				panel.classList.add(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				btn.querySelector("svg")?.classList.add("rotate-180");
			} else {
				panel.classList.add(
					"opacity-0",
					"-translate-y-2",
					"pointer-events-none",
				);
				panel.classList.remove(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				btn.querySelector("svg")?.classList.remove("rotate-180");
			}
		});

		// Toggle Articles in Categories
		const categoryToggles = document.querySelectorAll(
			".category-article-toggle",
		);
		categoryToggles.forEach((toggle) => {
			toggle.addEventListener("click", (e) => {
				e.stopPropagation();
				const group = toggle.closest(".category-group");
				const list = group?.querySelector(".article-list");
				const chevron = toggle.querySelector(".chevron");
				if (list) {
					const isHidden = list.classList.contains("hidden");
					if (isHidden) {
						list.classList.remove("hidden");
						chevron?.classList.add("rotate-180");
					} else {
						list.classList.add("hidden");
						chevron?.classList.remove("rotate-180");
					}
				}
			});
		});

		// Close when clicking outside
		document.addEventListener("click", (e) => {
			if (!panel.contains(e.target as Node) && e.target !== btn) {
				btn.setAttribute("aria-expanded", "false");
				panel.classList.add(
					"opacity-0",
					"-translate-y-2",
					"pointer-events-none",
				);
				panel.classList.remove(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				btn.querySelector("svg")?.classList.remove("rotate-180");
			}
		});
	}

	// Run on initial load and swap
	setupDropdown();
	document.addEventListener("astro:after-swap", setupDropdown);
</script>
