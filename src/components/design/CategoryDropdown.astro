---
import { getCollection } from "astro:content";
import { slugifyCategory } from "../../utils/slugify";
import { sortCategories, getCategoryDisplay, getCategoryIcon, HEADER_CATEGORIES } from "../../config/categories";

const articles = (await getCollection("articles")).filter(
	(a) => !a.id.startsWith("_"),
);

const groupedByCat = articles.reduce(
	(acc, a) => {
		const cat = getCategoryDisplay(a.data.category);
		if (!acc[cat]) acc[cat] = [];
		acc[cat].push(a);
		return acc;
	},
	{} as Record<string, typeof articles>,
);

interface Props {
	currentCategory?: string;
}

const { currentCategory } = Astro.props;
const { category: urlCategorySlug } = Astro.params;

// Helper to check if a category is active
const checkActive = (catDisplay: string) => {
	const slug = slugifyCategory(catDisplay);
	if (urlCategorySlug === slug) return true;
	if (currentCategory) {
		const normalizedCurrent = currentCategory.toLowerCase();
		return normalizedCurrent === slug || normalizedCurrent === catDisplay.toLowerCase();
	}
	return false;
};

const anyActive = !!urlCategorySlug || !!currentCategory;
---

<div class="relative flex items-center h-full">
	<button
		id="category-dropdown-btn"
		class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 font-bold transition-all border border-transparent dark:border-slate-700/50 shadow-sm whitespace-nowrap"
		aria-expanded="false"
	>
		<span>Themen</span>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="16"
			height="16"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			class="transition-transform duration-200"
			><path d="m6 9 6 6 6-6"></path></svg
		>
	</button>

	<div
		id="category-dropdown-panel"
		class="fixed left-1/2 -translate-x-1/2 top-20 w-[95vw] max-w-7xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-b-3xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] p-6 md:p-10 opacity-0 -translate-y-2 pointer-events-none transition-all duration-300 z-50 overflow-y-auto max-h-[85vh]"
	>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
			{
				Object.entries(HEADER_CATEGORIES).map(([headerName, categoryKeys]) => (
					<div class="header-section">
						<h3 class="text-[0.65rem] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-4 px-3">
							{headerName}
						</h3>
						
						<div class="space-y-1">
							{sortCategories(categoryKeys.map(getCategoryDisplay)).map((cat) => {
								const catArticles = groupedByCat[cat] || [];
								const slug = slugifyCategory(cat);
								const isActive = checkActive(cat);
								
								return (
									<div class="category-item group">
										<a
											href={`/KIWiki/category/${slug}`}
											class:list={[
												"flex items-start justify-between px-3 py-2.5 rounded-xl transition-all group",
												isActive 
													? "bg-blue-100 dark:bg-blue-900/50 text-blue-600 dark:text-blue-300 ring-1 ring-blue-500/30 shadow-sm" 
													: "hover:bg-blue-50 dark:hover:bg-blue-900/30 text-slate-700 dark:text-slate-200 hover:text-blue-600 dark:hover:text-blue-400"
											]}
										>
											<div class="flex items-start gap-3">
												<span class:list={[
													"text-xl shrink-0 transition-all duration-300",
													!anyActive 
														? "grayscale-0" 
														: (isActive ? "grayscale-0 scale-110" : "grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100")
												]}>{getCategoryIcon(cat)}</span>
												<span class="text-sm font-bold leading-tight">
													{cat}
												</span>
											</div>
											<span class:list={[
												"shrink-0 text-[0.65rem] font-mono px-1.5 py-0.5 rounded-md transition-colors mt-1",
												isActive
													? "bg-blue-500 text-white opacity-100 shadow-sm"
													: "opacity-40 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 group-hover:bg-white dark:group-hover:bg-slate-900"
											]}>
												{catArticles.length}
											</span>
										</a>
									</div>
								);
							})}
						</div>
					</div>
				))
			}
		</div>
	</div>

</div>

<script>
	function setupDropdown() {
		const btn = document.getElementById("category-dropdown-btn");
		const panel = document.getElementById("category-dropdown-panel");

		if (!btn || !panel) return;

		// Toggle Dropdown Main
		btn.addEventListener("click", (e) => {
			e.stopPropagation();
			const isExpanded = btn.getAttribute("aria-expanded") === "true";
			
			// Close tag dropdown if open
			const tagBtn = document.getElementById("tag-dropdown-btn");
			if (tagBtn && tagBtn.getAttribute("aria-expanded") === "true") {
				tagBtn.click();
			}

			btn.setAttribute("aria-expanded", String(!isExpanded));

			if (!isExpanded) {
				panel.classList.remove(
					"opacity-0",
					"-translate-y-2",
					"pointer-events-none",
				);
				panel.classList.add(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				btn.querySelector("svg")?.classList.add("rotate-180");
			} else {
				panel.classList.add(
					"opacity-0",
					"-translate-y-2",
					"pointer-events-none",
				);
				panel.classList.remove(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				btn.querySelector("svg")?.classList.remove("rotate-180");
			}
		});

		// Toggle Articles in Columns
		const headers = document.querySelectorAll(".category-header");
		headers.forEach((header) => {
			header.addEventListener("click", () => {
				const list = header
					.closest(".category-group")
					?.querySelector(".article-list");
				const chevron = header.querySelector(".chevron");
				if (list) {
					const isHidden = list.classList.contains("hidden");
					if (isHidden) {
						list.classList.remove("hidden");
						chevron?.classList.add("rotate-180");
					} else {
						list.classList.add("hidden");
						chevron?.classList.remove("rotate-180");
					}
				}
			});
		});

		// Close when clicking outside
		document.addEventListener("click", (e) => {
			if (!panel.contains(e.target as Node) && e.target !== btn) {
				btn.setAttribute("aria-expanded", "false");
				panel.classList.add(
					"opacity-0",
					"-translate-y-2",
					"pointer-events-none",
				);
				panel.classList.remove(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				btn.querySelector("svg")?.classList.remove("rotate-180");
			}
		});
	}

	// Run on initial load and swap
	setupDropdown();
	document.addEventListener("astro:after-swap", setupDropdown);
</script>
