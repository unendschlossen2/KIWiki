---
import CategoryDropdown from "./CategoryDropdown.astro";
import TagDropdown from "./TagDropdown.astro";
import ThemeToggle from "../theme/ThemeToggle.tsx";
import DifficultySelector from "../theme/DifficultySelector.tsx";
import { resolvePath } from "../../utils/path";

interface Props {
	isArticle?: boolean;
	category?: string;
}

const { isArticle, category } = Astro.props;
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 right-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 transition-colors duration-300"
>
    <!-- Reading Progress (Only on articles) -->
    {
        isArticle && (
            <div
                id="reading-progress"
                class="fixed top-0 left-0 h-1 bg-gradient-to-r from-blue-500 to-purple-600 transition-all duration-150 ease-out z-[60]"
                style="width: 0%;"
            />
        )
    }

    <div
        class="max-w-screen-2xl mx-auto px-6 h-20 flex items-center gap-6 relative z-10"
    >
        <!-- Left Area: Home & Categories -->
        <div class="flex items-center gap-4 shrink-0">
            <a
                href={resolvePath("/")}
                class="flex items-center justify-center w-11 h-11 rounded-xl bg-slate-100 hover:bg-white dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 transition-all border border-transparent dark:border-slate-700/50 shadow-sm hover:shadow group"
                aria-label="Zur Startseite"
                title="Startseite"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="group-hover:scale-110 transition-transform duration-200"
                    ><path
                        d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                    ></path><polyline points="9 22 9 12 15 12 15 22"
                    ></polyline></svg
                >
            </a>

            <CategoryDropdown currentCategory={category} />
            <TagDropdown />
        </div>

        <!-- Center Area: Search Bar -->
        <div class="flex-1 flex justify-center max-w-2xl px-4">
            <button
                onclick="window.openSearchModal && window.openSearchModal()"
                onmouseover="window.prefetchSearchIndex && window.prefetchSearchIndex()"
                onpointerenter="window.prefetchSearchIndex && window.prefetchSearchIndex()"
                class="flex items-center gap-3 px-6 py-3 w-full rounded-2xl bg-slate-100/80 hover:bg-white dark:bg-slate-800/80 dark:hover:bg-slate-800 text-slate-500 dark:text-slate-400 text-base font-medium transition-all border border-transparent hover:border-blue-500/30 dark:border-slate-700/50 dark:hover:border-blue-400/30 shadow-sm hover:shadow-md group overflow-hidden"
                aria-label="Suchen"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-search group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
                    ><circle cx="11" cy="11" r="8"></circle><path
                        d="m21 21-4.3-4.3"></path></svg
                >
                <span class="flex-1 text-left opacity-70"
                    >Suche nach Artikeln, Themen oder Begriffen...</span
                >
                <kbd
                    class="hidden md:inline-block font-sans text-[0.65rem] font-black uppercase tracking-widest bg-white dark:bg-slate-900 px-2 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 dark:text-slate-500 shadow-sm"
                    >Ctrl K</kbd
                >
            </button>
        </div>

        <!-- Right Area: Difficulty & Theme -->
        <div
            class="flex items-center gap-4 shrink-0 min-w-[120px] justify-end"
        >
            <ThemeToggle client:only="react" />
            <DifficultySelector client:only="react" />
        </div>
    </div>
</nav>
