---
import { resolvePath } from "../../utils/path";
import { ClientRouter } from "astro:transitions";

interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<head>
    <script is:inline define:vars={{ base }}>
        // Persistence — runs on every page load & View Transition
        (function () {
            function readDifficulty() {
                try {
                    var s = localStorage.getItem("kiwiki-difficulty");
                    if (s) {
                        var d = s.replace(/"/g, "");
                        if (d === "easy" || d === "medium" || d === "hard")
                            return d;
                    }
                } catch (e) {}
                return "easy";
            }

            function readTheme() {
                try {
                    var t = localStorage.getItem("kiwiki-theme");
                    if (t) return t.replace(/"/g, "");
                } catch (e) {}
                return "light";
            }

            function applySettings(doc) {
                var diff = readDifficulty();
                var theme = readTheme();
                doc.documentElement.setAttribute("data-difficulty", diff);
                var favicon = doc.querySelector('link[rel="icon"]');
                var basePath = base || "/";
                var cleanBase = basePath.endsWith("/")
                    ? basePath.slice(0, -1)
                    : basePath;
                if (theme === "dark") {
                    doc.documentElement.classList.add("dark");
                    if (favicon)
                        favicon.href = cleanBase + "/assets/logo-dark.png";
                } else {
                    doc.documentElement.classList.remove("dark");
                    if (favicon) favicon.href = cleanBase + "/assets/logo.png";
                }
            }

            // 1. Apply immediately
            applySettings(document);

            // 2. Register astro:before-swap
            if (!window._kiwikiSwapInit) {
                window._kiwikiSwapInit = true;
                document.addEventListener("astro:before-swap", function (ev) {
                    applySettings(ev.newDocument);
                });
            }
        })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href={resolvePath("/assets/logo.png")} />
    <link rel="icon" href={resolvePath("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
    <title>{title}</title>
    <ClientRouter />
</head>
