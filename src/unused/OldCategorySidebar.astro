---
/* 
  Unused Sidebar Animation Code
  Extracted from src/pages/category/[category].astro
*/
---

<!-- HTML Markup -->
<div class="library-tile sidebar-animation-tile">
  <div class="reactor-sidebar">
    <!-- Matrix rain background -->
    <div class="matrix-rain">
      {
        Array.from({ length: 8 }).map((_, i) => (
          <div class={`rain-col rc-${i}`}>
            {Array.from({ length: 40 }).map((_, j) => (
              <span class={`rain-char rch-${(i * 40 + j) % 12}`}>
                {
                  [
                    "0",
                    "1",
                    "λ",
                    "Σ",
                    "π",
                    "∞",
                    "Δ",
                    "∇",
                    "θ",
                    "ψ",
                    "α",
                    "β",
                  ][j % 12]
                }
              </span>
            ))}
          </div>
        ))
      }
    </div>

    <!-- Holographic scan beam -->
    <div class="holo-scan"></div>

    <div class="reactor-scroll-content">
      {
        Array.from({ length: 20 }).map((_, setIndex) => (
          <Fragment>
            <div
              class="reactor-core-wrap"
              style={`transform: rotate(${Math.random() * 360}deg) scale(${0.8 + Math.random() * 0.4});`}
            >
              <div class="reactor-scene">
                <div class="orbit-ring ring-1" />
                <div class="orbit-ring ring-2" />
                <div class="orbit-ring ring-3" />
                <div class="energy-core">
                  <div class="core-inner" />
                  <div class="core-pulse" />
                  <div class="core-pulse cp-2" />
                </div>
                <div class="electron e-1" />
                <div class="electron e-2" />
                <div class="electron e-3" />
              </div>
            </div>

            <div class="dna-helix">
              {Array.from({ length: 16 }).map((_, i) => (
                <div class={`dna-pair dp-${i}`}>
                  <div class="dna-dot dot-l" />
                  <div class="dna-bridge" />
                  <div class="dna-dot dot-r" />
                </div>
              ))}
            </div>
          </Fragment>
        ))
      }
    </div>

    <!-- Status terminal -->
    <div class="status-panel">
      <div class="terminal-header">
        <span class="term-dot td-r"></span>
        <span class="term-dot td-y"></span>
        <span class="term-dot td-g"></span>
        <span class="term-title">neural_core_v4.2</span>
      </div>
      <div class="status-line sl-1">&gt; QUANTUM_SYNC ......... OK</div>
      <div class="status-line sl-2">
        &gt; NEURAL_MESH .......... ACTIVE
      </div>
      <div class="status-line sl-3">
        &gt; DATA_FLOW ............ 1.2 TB/s
      </div>
      <div class="status-line sl-4">
        &gt; CORE_TEMP ............ 0.004K
      </div>
      <div class="status-line sl-5 blink-line">█</div>
    </div>
  </div>
</div>

<style>
  .sidebar-animation-tile {
    grid-column: 4;
    grid-row: 1 / span 1000;
    background: #0a0e1a;
    padding: 0;
    border-left: 1px solid rgba(99, 102, 241, 0.15);
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  :global(html:not(.dark)) .sidebar-animation-tile {
    background: #f8fafc;
    border-left: 1px solid rgba(99, 102, 241, 0.1);
  }

  .sidebar-animation-tile:hover {
    border-color: rgba(99, 102, 241, 0.15) !important;
    box-shadow: none !important;
  }

  .reactor-sidebar {
    position: sticky;
    top: 100px;
    height: calc(100vh - 150px);
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0;
    overflow: hidden;
  }

  .reactor-scroll-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
    padding: 2rem 0;
    height: 100%;
  }

  /* ── Matrix Rain ─────────────────────────────── */
  .matrix-rain {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: space-around;
    pointer-events: none;
    z-index: 0;
  }

  .rain-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: rain-fall 12s linear infinite;
    opacity: 0.12;
  }

  .rain-char {
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    color: #6366f1;
    text-shadow: 0 0 6px #6366f1;
    line-height: 1;
  }

  :global(html:not(.dark)) .rain-char {
    color: #4338ca;
    text-shadow: 0 0 2px rgba(99, 102, 241, 0.3);
    opacity: 0.2;
  }

  .rc-0 { animation-duration: 14s; }
  .rc-1 { animation-duration: 10s; animation-delay: -3s; }
  .rc-2 { animation-duration: 16s; animation-delay: -7s; }
  .rc-3 { animation-duration: 11s; animation-delay: -2s; }
  .rc-4 { animation-duration: 13s; animation-delay: -5s; }
  .rc-5 { animation-duration: 9s; animation-delay: -8s; }
  .rc-6 { animation-duration: 15s; animation-delay: -1s; }
  .rc-7 { animation-duration: 12s; animation-delay: -4s; }

  @keyframes rain-fall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  /* ── Holographic Scan Beam ──────────────────── */
  .holo-scan {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(99, 102, 241, 0.06) 30%,
      rgba(99, 102, 241, 0.12) 50%,
      rgba(99, 102, 241, 0.06) 70%,
      transparent 100%
    );
    animation: holo-sweep 6s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes holo-sweep {
    0%, 100% { top: -120px; }
    50% { top: calc(100% + 120px); }
  }

  /* ── 3D Reactor Core ────────────────────────── */
  .reactor-core-wrap {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    perspective: 800px;
    width: 200px;
    height: 200px;
    margin: 2rem auto;
  }

  .reactor-scene {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
  }

  .orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 160px;
    height: 160px;
    margin: -80px 0 0 -80px;
    border: 1.5px solid rgba(99, 102, 241, 0.25);
    border-radius: 50%;
    transform-style: preserve-3d;
  }

  .ring-1 {
    animation: orbit-spin-1 12s linear infinite;
    border-color: rgba(99, 102, 241, 0.3);
  }
  .ring-2 {
    width: 120px;
    height: 120px;
    margin: -60px 0 0 -60px;
    animation: orbit-spin-2 16s linear infinite;
    border-color: rgba(168, 85, 247, 0.25);
  }
  .ring-3 {
    width: 180px;
    height: 180px;
    margin: -90px 0 0 -90px;
    animation: orbit-spin-3 20s linear infinite reverse;
    border-color: rgba(59, 130, 246, 0.2);
    border-style: dashed;
  }

  @keyframes orbit-spin-1 {
    from { transform: rotateX(70deg) rotateZ(0deg); }
    to   { transform: rotateX(70deg) rotateZ(360deg); }
  }
  @keyframes orbit-spin-2 {
    from { transform: rotateX(50deg) rotateY(30deg) rotateZ(0deg); }
    to   { transform: rotateX(50deg) rotateY(30deg) rotateZ(360deg); }
  }
  @keyframes orbit-spin-3 {
    from { transform: rotateX(85deg) rotateY(-20deg) rotateZ(0deg); }
    to   { transform: rotateX(85deg) rotateY(-20deg) rotateZ(360deg); }
  }

  /* ── Energy Core ────────────────────────────── */
  .energy-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 40px;
    height: 40px;
    margin: -20px 0 0 -20px;
  }

  .core-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: radial-gradient(circle, #818cf8 0%, #6366f1 40%, #4338ca 100%);
    box-shadow:
      0 0 30px rgba(99, 102, 241, 0.6),
      0 0 60px rgba(99, 102, 241, 0.3),
      0 0 100px rgba(99, 102, 241, 0.15);
    animation: core-breathe 4s ease-in-out infinite;
  }

  .core-pulse {
    position: absolute;
    inset: -15px;
    border: 1px solid rgba(99, 102, 241, 0.4);
    border-radius: 50%;
    animation: core-expand 3s ease-out infinite;
  }
  .cp-2 { animation-delay: 1.5s; }

  @keyframes core-breathe {
    0%, 100% { transform: scale(1); filter: brightness(1); }
    50% { transform: scale(1.15); filter: brightness(1.4); }
  }

  @keyframes core-expand {
    0% { transform: scale(0.8); opacity: 0.6; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  /* ── Electrons ──────────────────────────────── */
  .electron {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #c4b5fd;
    box-shadow: 0 0 10px #8b5cf6, 0 0 20px rgba(139, 92, 246, 0.4);
  }

  .e-1 { top: 50%; left: 50%; animation: electron-orbit-1 6s linear infinite; }
  .e-2 { top: 50%; left: 50%; animation: electron-orbit-2 8s linear infinite; }
  .e-3 { top: 50%; left: 50%; animation: electron-orbit-3 10s linear infinite; }

  @keyframes electron-orbit-1 {
    0%   { transform: translate(-3px, -3px) rotate(0deg) translateX(80px) rotate(0deg); }
    100% { transform: translate(-3px, -3px) rotate(360deg) translateX(80px) rotate(-360deg); }
  }
  @keyframes electron-orbit-2 {
    0%   { transform: translate(-3px, -3px) rotate(120deg) rotate(0deg) translateX(60px) rotate(0deg); }
    100% { transform: translate(-3px, -3px) rotate(120deg) rotate(360deg) translateX(60px) rotate(-360deg); }
  }
  @keyframes electron-orbit-3 {
    0%   { transform: translate(-3px, -3px) rotate(240deg) rotate(0deg) translateX(90px) rotate(0deg); }
    100% { transform: translate(-3px, -3px) rotate(240deg) rotate(360deg) translateX(90px) rotate(-360deg); }
  }

  /* ── DNA Helix ──────────────────────────────── */
  .dna-helix {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin: 1rem auto;
    animation: dna-fade 8s ease-in-out infinite alternate;
    perspective: 1000px;
    transform-style: preserve-3d;
  }

  .dna-pair {
    display: flex;
    align-items: center;
    gap: 0;
    animation: dna-spin 4s linear infinite;
    transform-style: preserve-3d;
  }

  .dna-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-l { background: #6366f1; box-shadow: 0 0 6px #6366f1; }
  .dot-r { background: #a78bfa; box-shadow: 0 0 6px #a78bfa; }

  .dna-bridge {
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, #6366f1, transparent 50%, #a78bfa);
    opacity: 0.4;
  }

  @keyframes dna-spin {
    from { transform: rotateY(0deg); }
    to { transform: rotateY(360deg); }
  }

  @keyframes dna-fade {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* ── Status Terminal ────────────────────────── */
  .status-panel {
    position: relative;
    z-index: 2;
    width: calc(100% - 2rem);
    margin: auto 1rem 1rem;
    padding: 1rem;
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 12px;
    font-family: var(--font-mono, monospace);
    font-size: 0.6rem;
    color: #818cf8;
    backdrop-filter: blur(8px);
    transition: all 0.3s ease;
  }

  :global(html:not(.dark)) .status-panel {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(99, 102, 241, 0.2);
    color: #4338ca;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(99, 102, 241, 0.1);
  }

  .term-dot { width: 6px; height: 6px; border-radius: 50%; }
  .td-r { background: #ef4444; }
  .td-y { background: #eab308; }
  .td-g { background: #22c55e; }

  .term-title {
    margin-left: auto;
    font-size: 0.55rem;
    opacity: 0.5;
    letter-spacing: 0.05em;
  }

  .status-line {
    white-space: nowrap;
    overflow: hidden;
    line-height: 1.8;
    opacity: 0.7;
  }

  .sl-1 { animation: type-in 1.5s steps(30) 0.5s both; }
  .sl-2 { animation: type-in 1.5s steps(30) 1.5s both; }
  .sl-3 { animation: type-in 1.5s steps(30) 2.5s both; }
  .sl-4 { animation: type-in 1.5s steps(30) 3.5s both; }

  .blink-line {
    animation: cursor-blink 1s step-end infinite;
    opacity: 1;
  }

  @keyframes type-in {
    from { width: 0; }
    to { width: 100%; }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
