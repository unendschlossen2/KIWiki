---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404: Seite nicht gefunden">
  <div class="error-container">
    <div class="logo-container">
      <img
        src="/KIWiki/assets/logo.png"
        alt="KIWiki Logo"
        class="error-logo dark:hidden"
      />
      <img
        src="/KIWiki/assets/logo-dark.png"
        alt="KIWiki Logo"
        class="error-logo hidden dark:block"
      />
    </div>
    <div class="error-code">404</div>
    <h1>Ups! Seite nicht gefunden.</h1>
    <p class="error-message">
      Die gesuchte Seite existiert nicht oder wurde möglicherweise verschoben.
    </p>
    <div class="divider"></div>
    <div class="card-footer" style="margin-top: 2rem;">
      <a href="/KIWiki/" class="explore-btn"> ← Zurück zur Startseite </a>
    </div>
  </div>
</Layout>

<style>
  .error-container {
    text-align: center;
    padding: 6rem 1rem;
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .logo-container {
    width: 120px;
    height: 120px;
    margin-bottom: 1.5rem;
    animation: float 3s ease-in-out infinite;
  }

  .error-logo {
    width: 100%;
    height: 100%;
    object-contain: contain;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .error-code {
    font-size: 8rem;
    font-weight: 900;
    color: var(--primary-color);
    line-height: 1;
    margin-bottom: 1rem;
    opacity: 0.2;
    background: linear-gradient(
      135deg,
      var(--primary-color) 0%,
      var(--primary-hover) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 1rem;
    letter-spacing: -0.025em;
  }

  .error-message {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .divider {
    width: 4rem;
    height: 4px;
    background: var(--primary-color);
    border-radius: 2px;
  }

  .explore-btn {
    display: inline-block;
    color: var(--primary-color);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border: 2px solid var(--primary-color);
    border-radius: 9999px;
    transition: all 0.2s;
  }

  .explore-btn:hover {
    background: var(--bg-active);
  }
</style>
