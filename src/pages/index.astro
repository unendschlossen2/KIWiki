---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { slugifyCategory } from "../utils/slugify";
import {
	categoryIcons,
	getCategoryDisplay,
	getCategoryIcon,
	HEADER_CATEGORIES,
	sortCategories,
	CATEGORIES,
} from "../config/categories";
import { resolvePath } from "../utils/path";

const articles = (await getCollection("articles")).filter(
	(a) => !a.id.startsWith("_"),
);

// Group articles by category
const groupedArticles = articles.reduce(
	(acc, article) => {
		const category = getCategoryDisplay(article.data.category);
		if (!acc[category]) acc[category] = [];
		acc[category].push(article);
		return acc;
	},
	{} as Record<string, typeof articles>,
);
---

<Layout title="Willkommen beim KIWiki">
	<section class="hero-welcome">
		<div class="hero-main">
			<div class="hero-logo-container">
				<img
					src={resolvePath("/assets/logo.png")}
					alt="KIWiki Logo"
					class="hero-logo dark:hidden"
				/>
				<img
					src={resolvePath("/assets/logo-dark.png")}
					alt="KIWiki Logo"
					class="hero-logo hidden dark:block"
				/>
			</div>
			<div class="hero-text">
				<div class="flex flex-col gap-4 mb-6">
					<h1 class="!mb-0">
						Willkommen beim <span class="text-gradient">KIWiki</span
						>
					</h1>

					<div class="difficulty-showcase">
						<div
							class="showcase-badge badge-easy"
							data-difficulty="easy"
						>
							<span class="text-3xl">🌱</span>
							<div class="showcase-label">Einsteiger</div>
						</div>
						<div
							class="showcase-badge badge-medium"
							data-difficulty="medium"
						>
							<span class="text-3xl">🚀</span>
							<div class="showcase-label">Fortgeschritten</div>
						</div>
						<div
							class="showcase-badge badge-hard"
							data-difficulty="hard"
						>
							<span class="text-3xl">🧠</span>
							<div class="showcase-label">Experte</div>
						</div>
					</div>
				</div>

				<p class="subtitle">
					Entdecke die Welt der Künstlichen Intelligenz – angepasst an
					dein Vorwissen.
				</p>
			</div>
		</div>
	</section>

	<section class="hero-about">
		<div
			class="about-card bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800"
		>
			<div class="about-icon bg-white dark:bg-slate-800">ℹ️</div>
			<div class="about-content">
				<h3 class="about-title">Über das Projekt</h3>
				<p class="about-text">
					Erfahre mehr über die Vision hinter KIWiki und wie dieses
					Projekt Wissen vermittelt.
				</p>
				<a href={resolvePath("/ueber")} class="about-link stretched-link">
					Mehr erfahren →
				</a>
			</div>
		</div>
	</section>

	{
		Object.entries(HEADER_CATEGORIES).map(
			([headerName, categoryKeys], index) => (
				<section
					class={`library-section section-split-${index % 2 === 0 ? "left" : "right"}`}
				>
					<div class="section-decor">
						<span class="section-index">0{index + 1}</span>
						<div class="line-glow" />
					</div>

					<div class="library-content">
						<header class="library-header">
							<h2 class="library-title">{headerName}</h2>
							<div class="title-underline" />
						</header>

						<div class="library-grid">
							{sortCategories(
								categoryKeys.map(getCategoryDisplay),
							).map((category) => {
								const items = groupedArticles[category] || [];
								const categoryKey =
									Object.keys(CATEGORIES).find(
										(k) =>
											CATEGORIES[k].display === category,
									) || "allgemein";

								return (
									<div
										class={`library-tile accent-${categoryKey}`}
									>
										<div class="tile-icon-wrap">
											<span class="tile-emoji">
												{getCategoryIcon(category)}
											</span>
										</div>
										<div class="tile-main">
											<div class="tile-top">
												<h3 class="tile-title">
													{category}
												</h3>
												<span class="tile-count">
													{items.length}
												</span>
											</div>

											<p class="tile-description">
												{CATEGORIES[categoryKey]?.description || "Entdecke spannende Artikel zu diesem Thema."}
											</p>

											<a
												href={resolvePath(`/category/${slugifyCategory(category)}`)}
												class="tile-link stretched-link"
											>
												Inhalt ansehen{" "}
												<svg
													xmlns="http://www.w3.org/2000/svg"
													width="16"
													height="16"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2.5"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<line
														x1="5"
														y1="12"
														x2="19"
														y2="12"
													/>
													<polyline points="12 5 19 12 12 19" />
												</svg>
											</a>
										</div>
									</div>
								);
							})}
						</div>
					</div>
				</section>
			),
		)
	}
</Layout>

<style>
	/* --- Hero & Layout --- */
	.hero-welcome {
		padding: 4rem 0 2rem;
		width: 100%;
	}

	.hero-about {
		padding: 0 0 6rem;
		width: 100%;
	}

	.hero-main {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 2.5rem;
		max-width: 1300px;
		margin: 0 auto;
	}

	.hero-about .about-card {
		max-width: 1300px;
		margin: 0 auto;
	}

	@media (min-width: 640px) {
		.hero-main {
			flex-direction: row;
			text-align: left;
			gap: 4rem;
		}
	}

	.hero-logo-container {
		flex-shrink: 0;
		perspective: 1000px;
	}

	.hero-logo {
		width: 320px;
		height: auto;
		filter: drop-shadow(0 40px 60px var(--shadow-color));
		animation: float 6s ease-in-out infinite;
		border-radius: 64px;
	}

	@media (min-width: 1280px) {
		.hero-logo {
			width: 420px;
		}
	}

	.hero-text {
		flex: 1;
	}

	.hero-section h1 {
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 900;
		color: var(--text-primary);
		line-height: 1.1;
		letter-spacing: -0.04em;
	}

	.text-gradient {
		background: linear-gradient(135deg, #2563eb, #7c3aed);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.subtitle {
		font-size: 1.25rem;
		color: var(--text-secondary);
		line-height: 1.6;
		max-width: 500px;
	}

	/* Difficulty Showcase Fix */
	.difficulty-showcase {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	.showcase-badge {
		padding: 0.6rem 1.25rem;
		border-radius: 16px;
		border: 2px solid transparent;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: var(--bg-card);
		font-size: 0.9rem;
		font-weight: 800;
		color: var(--text-secondary);
		transition: all 0.3s ease;
		opacity: 0.5;
	}

	.active-badge {
		opacity: 1 !important;
		transform: scale(1.05);
		box-shadow: 0 10px 20px -5px var(--shadow-hover);
	}

	.showcase-badge.badge-easy {
		color: #16a34a;
	}
	.showcase-badge.badge-medium {
		color: #2563eb;
	}
	.showcase-badge.badge-hard {
		color: #7c3aed;
	}

	.active-badge.badge-easy {
		background: #16a34a !important;
		color: white !important;
		border-color: #0d9488;
		opacity: 1 !important;
		transform: scale(1.05);
	}
	.active-badge.badge-medium {
		background: #2563eb !important;
		color: white !important;
		border-color: #1d4ed8;
		opacity: 1 !important;
		transform: scale(1.05);
	}
	.active-badge.badge-hard {
		background: #7c3aed !important;
		color: white !important;
		border-color: #6d28d9;
		opacity: 1 !important;
		transform: scale(1.05);
	}

	/* Mode-Specific Colors (Astro Scoped) */
	:global(html.dark) .showcase-badge {
		background: rgba(30, 41, 59, 0.5);
		border-color: rgba(51, 65, 85, 0.5);
	}

	:global(html.dark) .showcase-badge.badge-easy {
		color: #4ade80;
	}
	:global(html.dark) .showcase-badge.badge-medium {
		color: #60a5fa;
	}
	:global(html.dark) .showcase-badge.badge-hard {
		color: #a78bfa;
	}

	:global(html.dark) .active-badge.badge-easy {
		background: #22c55e !important;
		color: white !important;
	}
	:global(html.dark) .active-badge.badge-medium {
		background: #3b82f6 !important;
		color: white !important;
	}
	:global(html.dark) .active-badge.badge-hard {
		background: #9333ea !important;
		color: white !important;
	}

	/* Side Card (About KIWiki) */
	.about-card {
		background: linear-gradient(135deg, #f8fafc, #eff6ff);
		border-radius: 32px;
		padding: 2.5rem;
		display: flex;
		gap: 1.5rem;
		position: relative;
		box-shadow: 0 25px 50px -12px var(--shadow-color);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
	}

	:global(html.dark) .about-card {
		background: linear-gradient(135deg, #334155, #1e3a8a30);
	}

	:global(html.dark) .about-icon {
		background: #1e293b;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
	}

	:global(html.dark) .about-title {
		color: white;
	}
	:global(html.dark) .about-text {
		color: #94a3b8;
	}
	:global(html.dark) .about-link {
		color: #60a5fa;
	}

	.about-icon {
		font-size: 2.5rem;
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 20px;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
		flex-shrink: 0;
	}

	.about-title {
		font-size: 1.5rem;
		font-weight: 900;
		color: var(--text-primary);
		margin-bottom: 0.75rem;
	}

	.about-text {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 2rem;
	}

	.about-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: #2563eb;
		font-weight: 800;
		text-decoration: none;
		font-size: 0.9rem;
	}

	.about-link:hover {
		text-decoration: underline;
	}

	.tile-description {
		font-size: 1rem;
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 1.5rem 0 2rem 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		min-height: 3em;
	}

	/* --- Library Layout --- */
	.library-section {
		display: grid;
		grid-template-columns: 100px 1fr;
		gap: 4rem;
		margin-bottom: 8rem;
		position: relative;
	}

	@media (max-width: 768px) {
		.library-section {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	.section-decor {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-top: 0.5rem;
	}

	.section-index {
		font-family: var(--font-mono);
		font-weight: 800;
		font-size: 1.25rem;
		color: var(--primary-color);
		opacity: 0.3;
	}

	.line-glow {
		width: 2px;
		flex-grow: 1;
		background: linear-gradient(
			to bottom,
			var(--primary-color),
			transparent
		);
		border-radius: 2px;
		opacity: 0.2;
	}

	.library-header {
		margin-bottom: 3rem;
	}

	.library-title {
		font-size: 2.25rem;
		font-weight: 900;
		color: var(--text-primary);
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}

	.title-underline {
		width: 60px;
		height: 4px;
		background: var(--primary-color);
		border-radius: 2px;
	}

	.library-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
		gap: 2rem;
	}

	@media (max-width: 480px) {
		.library-grid {
			grid-template-columns: 1fr;
		}
	}

	.library-tile {
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: 24px;
		padding: 2rem;
		display: flex;
		gap: 1.5rem;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		position: relative;
		overflow: hidden;
	}

	.library-tile:hover {
		transform: translateY(-8px) scale(1.02);
		border-color: var(--primary-color);
		box-shadow: 0 20px 40px -10px var(--shadow-hover);
	}

	.tile-icon-wrap {
		width: 64px;
		height: 64px;
		background: var(--bg-page);
		border-radius: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.25rem;
		flex-shrink: 0;
		transition: transform 0.3s ease;
	}

	.library-tile:hover .tile-icon-wrap {
		transform: rotate(-5deg) scale(1.1);
	}

	.tile-main {
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}

	.tile-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1rem;
	}

	.tile-title {
		font-size: 1.25rem;
		font-weight: 800;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.2;
	}

	.tile-count {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 700;
		background: var(--primary-color-alpha);
		color: var(--primary-color);
		padding: 2px 8px;
		border-radius: 6px;
	}

	.tile-link {
		margin-top: auto;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--primary-color);
		text-decoration: none;
	}

	.tile-link svg {
		transition: transform 0.2s;
	}

	.library-tile:hover .tile-link svg {
		transform: translateX(4px);
	}

	.stretched-link::after {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		left: 0;
		z-index: 1;
		content: "";
	}

	.difficulty-hidden {
		display: none !important;
	}
</style>

<script>
	import { difficultyStore } from "../components/design/difficultyStore";

	function updateHeroBadges(difficulty: string) {
		const badges = document.querySelectorAll(".showcase-badge");
		badges.forEach((badge) => {
			if ((badge as HTMLElement).dataset.difficulty === difficulty) {
				badge.classList.add("active-badge");
			} else {
				badge.classList.remove("active-badge");
			}
		});
	}

	// Variable zum Speichern der Kündigung des Abonnements
	let unsubscribe: () => void;

	document.addEventListener("astro:page-load", () => {
		// Altes Abonnement aufräumen
		if (unsubscribe) unsubscribe();

		unsubscribe = difficultyStore.subscribe((newDifficulty) => {
			// Trigger immediate update
			updateHeroBadges(newDifficulty);
		});

		// Initial sweep
		const currentDifficulty = difficultyStore.get();
		updateHeroBadges(currentDifficulty);
	});
</script>
